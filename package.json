{
  "name": "garmin-cloud",
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.4",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "preview:worker": "astro build && pnpm exec wrangler dev",
    "deploy": "astro build && pnpm exec wrangler deploy",
    "astro": "astro",
    "check": "biome check .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "generate-types": "pnpm exec wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.2",
    "@astrojs/react": "^6.0.1",
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@hookform/resolvers": "^5.4.0",
    "@shadcn/react": "^0.2.1",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^7.0.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.24.0",
    "next-themes": "^0.4.6",
    "oauth-1.0a": "^2.2.6",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-resizable-panels": "^4.12.2",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "wrangler": "^4.110.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.5.3",
    "@types/node": "22",
    "typescript": "^5.7.3"
  }
}
