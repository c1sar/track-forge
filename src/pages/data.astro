---
import { TrackForgeApp } from '@/features/app-shell/components/TrackForgeApp';
import Layout from '@/layouts/Layout.astro';

const currentUser = Astro.locals.currentUser;
if (!currentUser) {
  return Astro.redirect('/login');
}
---

<Layout title="Data & Export · TrackForge" bare>
  <TrackForgeApp
    userEmail={currentUser.email}
    currentPage="data"
    client:load
    transition:persist="trackforge-shell"
  />
</Layout>
