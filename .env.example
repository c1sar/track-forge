# Secretos de la aplicación.
#
# Local (wrangler dev): copia estos valores en `.dev.vars` (git-ignored).
# Producción: configúralos como secretos del Worker con:
#   wrangler secret put TOKEN_ENCRYPTION_KEY
#   wrangler secret put SESSION_SECRET
#
# Los bindings de infraestructura (D1 "DB", KV "APP_KV") se declaran en
# wrangler.jsonc, no aquí.

# Clave AES-256 en base64 (32 bytes). Generar con:
#   node -e "console.log(Buffer.from(crypto.getRandomValues(new Uint8Array(32))).toString('base64'))"
TOKEN_ENCRYPTION_KEY=

# Secreto para la capa de sesión (cadena aleatoria larga).
SESSION_SECRET=
